{
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "gemini": {
      "default_config_options": {
        "approvalMode": "yolo"
      },
      "favorite_config_option_values": {
        "approvalMode": ["yolo"]
      },
      "type": "registry"
    },
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": ["dontAsk"]
      },
      "default_config_options": {
        "mode": "bypassPermissions"
      },
      "default_mode": "bypassPermissions",
      "env": {
        "ANTHROPIC_MODEL": "sonnet"
      },
      "type": "registry"
    },
    "codex-acp": {
      "default_config_options": {
        "approval_policy": "never",
        "sandbox_mode": "danger-full-access"
      },
      "favorite_config_option_values": {
        "approval_policy": ["never"],
        "sandbox_mode": ["danger-full-access"]
      },
      "type": "registry"
    }
  },
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "terminal": {
          "default": "confirm"
        },
        "edit_file": {
          "default": "confirm"
        }
      }
    },
    "expand_edit_card": false,
    "expand_terminal_card": false,
    "use_modifier_to_send": false,
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    }
  },
  "features": {
    "edit_prediction_provider": "zed"
  },
  "icon_theme": "Material Icon Theme",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": "Catppuccin Latte",
  "terminal": {
    "font_family": "Cascadia Code PL",
    "font_size": 13,
    "font_features": {
      "calt": true
    },
    "line_height": {
      "custom": 1.6
    },
    "cursor_shape": "bar",
    "env": {
      "COLORTERM": "truecolor"
    }
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/.claude",
    "**/.codex",
    "**/.cursor",
    "**/.venv",
    "**/node_modules",
    "**/.pnpm-store",
    "**/.turbo",
    "**/.svelte-kit",
    "**/.next",
    "**/dist",
    "**/build"
  ],
  "auto_install_extensions": {
    "html": true,
    "svelte": true,
    "catppuccin": true,
    "material-icon-theme": true,
    "biome": true
  },
  "lsp": {
    "protobuf-language-server": {
      "binary": {
        "path": "buf",
        "arguments": ["beta", "lsp"]
      }
    }
  },
  "languages": {
    "YAML": {
      "format_on_save": "off"
    },
    "Python": {
      "language_servers": ["py", "ruff"],
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "ruff"
          },
          "code_actions": {
            "source.organizeImports.ruff": false,
            "source.fixAll.ruff": true
          }
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  }
}
